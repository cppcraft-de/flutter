+uint32_t OneLineShaper::shapingFeatureMask(SkSpan<const SkShaper::Feature> features) const {
+    uint32_t mask = 0;
+    for (const SkShaper::Feature& feature : features) {
+        if (feature.tag == SkSetFourByteTag('k', 'e', 'r', 'n')) {
+            mask |= 1u << 0;
+        } else if (feature.tag == SkSetFourByteTag('l', 'i', 'g', 'a')) {
+            mask |= 1u << 1;
+        } else if (feature.tag == SkSetFourByteTag('c', 'l', 'i', 'g')) {
+            mask |= 1u << 2;
+        } else if (feature.tag == SkSetFourByteTag('d', 'l', 'i', 'g')) {
+            mask |= 1u << 3;
+        } else if (feature.tag == SkSetFourByteTag('h', 'l', 'i', 'g')) {
+            mask |= 1u << 4;
+        } else if (feature.tag == SkSetFourByteTag('c', 'a', 'l', 't')) {
+            mask |= 1u << 5;
+        } else {
+            mask |= 1u << 31;
+        }
+    }
+    return mask;
+}
