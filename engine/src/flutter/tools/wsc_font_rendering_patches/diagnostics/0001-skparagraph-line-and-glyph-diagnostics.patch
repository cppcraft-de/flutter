+bool getLegacyPairKerningX(const SkFont& font,
+                           SkGlyphID firstGlyph,
+                           SkGlyphID secondGlyph,
+                           SkScalar* kerning) {
+    SkASSERT(kerning);
+    *kerning = 0;
+
+    SkTypeface* typeface = font.getTypeface();
+    if (!typeface) {
+        return false;
+    }
+
+    SkGlyphID glyphs[2] = {firstGlyph, secondGlyph};
+    int32_t adjustment = 0;
+    if (!typeface->getKerningPairAdjustments({glyphs, 2}, {&adjustment, 1})) {
+        return false;
+    }
+
+    int unitsPerEm = typeface->getUnitsPerEm();
+    if (unitsPerEm <= 0) {
+        return false;
+    }
+
+    *kerning = SkIntToScalar(adjustment) * font.getSize() / SkIntToScalar(unitsPerEm);
+    if (!font.isSubpixel()) {
+        *kerning = SkScalarRoundToInt(*kerning);
+    }
+    return true;
+}
