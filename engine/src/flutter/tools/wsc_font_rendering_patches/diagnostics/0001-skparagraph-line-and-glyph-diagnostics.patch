+std::vector<Paragraph::GlyphDiagnostic> ParagraphImpl::getGlyphDiagnostics() {
+    std::vector<Paragraph::GlyphDiagnostic> result;
+    int lineNumber = 0;
+    for (auto& line : fLines) {
+        line.ensureTextBlobCachePopulated();
+        for (auto& rec : line.fTextBlobCache) {
+            if (rec.fBlob == nullptr || rec.fVisitor_Run == nullptr) {
+                continue;
+            }
+            const Run* sourceRun = rec.fVisitor_Run;
+            size_t sourceIndex = rec.fVisitor_Pos;
+            SkTextBlob::Iter iter(*rec.fBlob);
+            SkTextBlob::Iter::ExperimentalRun blobRun;
+            while (iter.experimentalNext(&blobRun)) {
+                for (int i = 0; i < blobRun.count; ++i, ++sourceIndex) {
+                    const SkPoint rawShapePosition = sourceRun->rawPosition(sourceIndex);
+                    const SkVector rawAdvance =
+                            sourceRun->rawPosition(sourceIndex + 1) - rawShapePosition;
+                    const SkPoint shapePosition = sourceRun->fPositions[sourceIndex];
+                    const SkPoint offset = sourceRun->fOffsets[sourceIndex];
+                    const SkVector advance =
+                            sourceRun->fPositions[sourceIndex + 1] - shapePosition;
+                    const SkPoint finalOrigin = blobRun.positions[i] + rec.fOffset;
+                    const SkRect bounds = blobRun.font.getBounds(blobRun.glyphs[i], nullptr);
+                    SkScalar legacyPairKerningX = 0;
+                    const bool legacyPairKerningAvailable =
+                            i + 1 < blobRun.count &&
+                            getLegacyPairKerningX(blobRun.font,
+                                                  blobRun.glyphs[i],
+                                                  blobRun.glyphs[i + 1],
+                                                  &legacyPairKerningX);
+                    SkScalar qtLikeAdvanceX = 0;
+                    SkTypeface* typeface = blobRun.font.getTypeface();
+                    const bool qtLikeAdvanceAvailable =
+                            typeface != nullptr &&
+                            typeface->getQtLikeGlyphAdvance(blobRun.glyphs[i],
+                                                            blobRun.font.getSize(),
+                                                            &qtLikeAdvanceX);
+                    SkFontMetrics fontMetrics;
+                    blobRun.font.getMetrics(&fontMetrics);
+                    result.push_back({
+                            lineNumber,
+                            sourceRun->fIndex,
+                            blobRun.font,
+                            fontMetrics,
+                            blobRun.glyphs[i],
+                            SkToU32(sourceRun->globalClusterIndex(sourceIndex)),
+                            SkToU32(sourceRun->fUtf8Range.begin()),
+                            SkToU32(sourceRun->fUtf8Range.end()),
+                            sourceRun->fBidiLevel,
+                            sourceRun->fScript,
+                            sourceRun->fLanguage,
+                            sourceRun->fShapingFeatureCount,
+                            sourceRun->fShapingFeatureMask,
+                            rawShapePosition,
+                            rawAdvance,
+                            legacyPairKerningX,
+                            legacyPairKerningAvailable,
+                            qtLikeAdvanceX,
+                            qtLikeAdvanceAvailable,
+                            shapePosition,
+                            offset,
+                            advance,
+                            finalOrigin,
+                            bounds,
+                            bounds.makeOffset(finalOrigin),
+                    });
+                }
+            }
+        }
+        lineNumber += 1;
+    }
+    return result;
+}
