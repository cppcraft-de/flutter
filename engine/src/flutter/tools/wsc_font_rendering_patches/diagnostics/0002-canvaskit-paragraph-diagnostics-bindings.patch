+JSArray GetGlyphDiagnostics(para::Paragraph& self) {
+    const auto glyphs = self.getGlyphDiagnostics();
+    JSArray result = emscripten::val::array();
+    for (const auto& glyph : glyphs) {
+        JSArray record = emscripten::val::array();
+        auto add_number = [&](double value) {
+            record.call<void>("push", value);
+        };
+        add_number(glyph.fLineNumber);
+        add_number(glyph.fRunIndex);
+        SkString family;
+        SkTypefaceID typefaceID = 0;
+        if (glyph.fFont.getTypeface() != nullptr) {
+            glyph.fFont.getTypeface()->getFamilyName(&family);
+            typefaceID = glyph.fFont.getTypeface()->uniqueID();
+        }
+        record.call<void>("push", std::string(family.c_str()));
+        add_number(typefaceID);
+        add_number(glyph.fFont.getSize());
+        add_number(glyph.fFont.isSubpixel() ? 1 : 0);
+        add_number(glyph.fFont.isLinearMetrics() ? 1 : 0);
+        add_number(static_cast<int>(glyph.fFont.getHinting()));
+        add_number(static_cast<int>(glyph.fFont.getEdging()));
+        add_number(glyph.fFontMetrics.fTop);
+        add_number(glyph.fFontMetrics.fAscent);
+        add_number(glyph.fFontMetrics.fDescent);
+        add_number(glyph.fFontMetrics.fBottom);
+        add_number(glyph.fFontMetrics.fLeading);
+        add_number(glyph.fGlyph);
+        add_number(glyph.fUtf8Cluster);
+        add_number(glyph.fRawShapePosition.fX);
+        add_number(glyph.fRawShapePosition.fY);
+        add_number(glyph.fRawAdvance.fX);
+        add_number(glyph.fRawAdvance.fY);
+        add_number(glyph.fShapePosition.fX);
+        add_number(glyph.fShapePosition.fY);
+        add_number(glyph.fOffset.fX);
+        add_number(glyph.fOffset.fY);
+        add_number(glyph.fAdvance.fX);
+        add_number(glyph.fAdvance.fY);
+        add_number(glyph.fFinalOrigin.fX);
+        add_number(glyph.fFinalOrigin.fY);
+        add_number(glyph.fBounds.fLeft);
+        add_number(glyph.fBounds.fTop);
+        add_number(glyph.fBounds.fRight);
+        add_number(glyph.fBounds.fBottom);
+        add_number(glyph.fInkBounds.fLeft);
+        add_number(glyph.fInkBounds.fTop);
+        add_number(glyph.fInkBounds.fRight);
+        add_number(glyph.fInkBounds.fBottom);
+        result.call<void>("push", record);
+    }
+    return result;
+}
