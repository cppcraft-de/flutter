+uint32_t diagnosticTableChecksum(SkTypeface* typeface, SkFontTableTag tag) {
+    if (!typeface) {
+        return 0;
+    }
+    sk_sp<SkData> data = typeface->copyTableData(tag);
+    if (!data) {
+        return 0;
+    }
+    uint32_t hash = 2166136261u;
+    const uint8_t* bytes = data->bytes();
+    for (size_t i = 0; i < data->size(); ++i) {
+        hash ^= bytes[i];
+        hash *= 16777619u;
+    }
+    return hash;
+}
+
+uint32_t diagnosticTableChecksum(SkTypeface* typeface, char a, char b, char c, char d) {
+    return diagnosticTableChecksum(typeface, SkSetFourByteTag(a, b, c, d));
+}
