+bool SkTypeface_Mac::onGetQtLikeGlyphAdvanceDiagnostics(
+        SkGlyphID glyph,
+        SkScalar textSize,
+        SkTypeface::QtLikeGlyphAdvanceDiagnostics* diagnostics) const {
+    if (!diagnostics) {
+        return false;
+    }
+    *diagnostics = {};
+
+    CGGlyph cgGlyph = static_cast<CGGlyph>(glyph);
+    CGSize advance = CGSizeZero;
+    SkUniqueCFRef<CTFontRef> sizedFont(CTFontCreateCopyWithAttributes(
+            fFontRef.get(), SkScalarToDouble(textSize), nullptr, nullptr));
+    CTFontRef font = sizedFont ? sizedFont.get() : fFontRef.get();
+    if (CTFontGetAdvancesForGlyphs(font, kCTFontOrientationHorizontal, &cgGlyph, &advance, 1) == 0) {
+        return false;
+    }
+
+    diagnostics->fAvailable = true;
+    diagnostics->fBackend = 2;
+    diagnostics->fAdvance = SkDoubleToScalar(advance.width);
+    diagnostics->fDesignAdvance = SkDoubleToScalar(advance.width);
+    diagnostics->fUnitsPerEm = this->getUnitsPerEm();
+    diagnostics->fDesignUnitsPerEm = diagnostics->fUnitsPerEm;
+    diagnostics->fNumGlyphs = this->countGlyphs();
+    return true;
+}
