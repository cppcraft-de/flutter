     return metrics.designUnitsPerEm;
 }
 
+bool DWriteFontTypeface::onGetQtLikeGlyphAdvanceDiagnostics(
+        SkGlyphID glyph,
+        SkScalar textSize,
+        SkTypeface::QtLikeGlyphAdvanceDiagnostics* diagnostics) const {
+    if (!diagnostics) {
+        return false;
+    }
+    *diagnostics = {};
+
+    UINT16 glyphId = glyph;
+    DWRITE_GLYPH_METRICS designMetrics = {};
+    if (FAILED(fDWriteFontFace->GetDesignGlyphMetrics(&glyphId, 1, &designMetrics))) {
+        return false;
+    }
+
+    DWRITE_FONT_METRICS fontMetrics = {};
+    fDWriteFontFace->GetMetrics(&fontMetrics);
+    if (fontMetrics.designUnitsPerEm == 0) {
+        return false;
+    }
+
+    diagnostics->fAvailable = true;
+    diagnostics->fBackend = 3;
+    diagnostics->fUnitsPerEm = fontMetrics.designUnitsPerEm;
+    diagnostics->fDesignUnitsPerEm = fontMetrics.designUnitsPerEm;
+    diagnostics->fNumGlyphs = this->countGlyphs();
+    diagnostics->fDesignAdvance =
+            textSize * SkIntToScalar(designMetrics.advanceWidth) /
+            SkIntToScalar(fontMetrics.designUnitsPerEm);
+    // DWrite's GDI-compatible metrics are useful diagnostics, but they are not
+    // FreeType's hinted slot advance.  Qt/FreeType gets that value from the
+    // TrueType loader after hint instructions move the phantom points; some
+    // fonts match DWrite GDI here, others do not.  Keep the selected correction
+    // neutral on DWrite until we have a real FreeType-backed metric source.
+    diagnostics->fAdvance = diagnostics->fDesignAdvance;
+
+    if (fDWriteFontFace1) {
+        DWRITE_GLYPH_METRICS gdiMetrics = {};
+        if (SUCCEEDED(fDWriteFontFace1->GetGdiCompatibleGlyphMetrics(
+                    textSize,
+                    1.0f,
+                    nullptr,
+                    DWRITE_MEASURING_MODE_GDI_NATURAL,
+                    &glyphId,
+                    1,
+                    &gdiMetrics,
+                    FALSE))) {
+            diagnostics->fGdiCompatibleAdvance =
+                    textSize * SkIntToScalar(gdiMetrics.advanceWidth) /
+                    SkIntToScalar(fontMetrics.designUnitsPerEm);
+            diagnostics->fMeasuringMode = DWRITE_MEASURING_MODE_GDI_NATURAL;
+        }
+    }
+    return true;
+}
