-    "src/pshinter/pshinter.c",
-    "src/psnames/psnames.c",
-    "src/sfnt/sfnt.c",
-    "src/smooth/smooth.c",
+    "$qt_compatible_freetype_dir/src/autofit/autofit.c",
+    "$qt_compatible_freetype_dir/src/base/ftbase.c",
+    "$qt_compatible_freetype_dir/src/base/ftbbox.c",
+    "$qt_compatible_freetype_dir/src/base/ftbdf.c",
