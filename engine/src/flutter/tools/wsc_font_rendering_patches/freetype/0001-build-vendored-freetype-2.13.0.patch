diff --git a/BUILD.gn b/BUILD.gn
index 72b0aec46..1cf5206de 100644
--- a/BUILD.gn
+++ b/BUILD.gn
@@ -31,10 +31,24 @@ declare_args() {
   flutter_use_freetype_woff2 = false
 }
 
+# WSC/Qt parity patch:
+# Build the stable Flutter GN label from the Qt-matching FreeType 2.13.0
+# source tree. Keep Flutter's trimmed module list below so existing native,
+# Android, and web dependencies on //flutter/third_party/freetype2 do not need
+# to change labels.
+qt_compatible_freetype_dir = "../freetype_2.13.0"
+
 config("freetype_config") {
   include_dirs = [
     "include/freetype-flutter-config",
-    "include",
+    "$qt_compatible_freetype_dir/include",
+  ]
+}
+
+config("freetype_private_config") {
+  include_dirs = [
+    "include/freetype-flutter-config",
+    "$qt_compatible_freetype_dir/include",
   ]
 
   cflags = []
@@ -45,10 +59,6 @@ config("freetype_config") {
       "-Wno-unused-variable",
     ]
   }
-}
-
-config("freetype_private_config") {
-  cflags = []
 
   if ((is_mac || is_ios) && is_clang) {
     cflags += [
@@ -59,40 +69,41 @@ config("freetype_private_config") {
 
 target(default_library_type, "freetype2") {
   sources = [
