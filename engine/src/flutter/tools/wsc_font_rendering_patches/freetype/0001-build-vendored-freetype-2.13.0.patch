+    "$qt_compatible_freetype_dir/src/base/fttype1.c",
+    "$qt_compatible_freetype_dir/src/base/ftsynth.c",
+    "$qt_compatible_freetype_dir/src/gzip/ftgzip.c",
+    "$qt_compatible_freetype_dir/src/lzw/ftlzw.c",
