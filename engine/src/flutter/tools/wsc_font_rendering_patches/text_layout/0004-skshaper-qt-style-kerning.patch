+bool skhb_glyph_h_kerning(const SkFont& font,
+                          SkGlyphID firstGlyph,
+                          SkGlyphID secondGlyph,
+                          SkScalar* kerning) {
+    SkASSERT(kerning);
+    *kerning = 0;
+
+    SkTypeface* typeface = font.getTypeface();
+    if (!typeface) {
+        return false;
+    }
+
+    SkGlyphID glyphs[2] = {firstGlyph, secondGlyph};
+    int32_t adjustment = 0;
+    if (!typeface->getKerningPairAdjustments({glyphs, 2}, {&adjustment, 1})) {
+        return false;
+    }
+
+    int unitsPerEm = typeface->getUnitsPerEm();
+    if (unitsPerEm <= 0) {
+        return false;
+    }
+
+    *kerning = SkIntToScalar(adjustment) * font.getSize() / SkIntToScalar(unitsPerEm);
+    if (!font.isSubpixel()) {
+        *kerning = SkScalarRoundToInt(*kerning);
+    }
+    return true;
+}
+
+hb_position_t skhb_glyph_h_kerning(hb_font_t* hb_font,
+                                   void* font_data,
+                                   hb_codepoint_t firstGlyph,
+                                   hb_codepoint_t secondGlyph,
+                                   void* user_data) {
+    SkFont& font = *reinterpret_cast<SkFont*>(font_data);
+    SkScalar kerning = 0;
+    if (!skhb_glyph_h_kerning(font,
+                              SkTo<SkGlyphID>(firstGlyph),
+                              SkTo<SkGlyphID>(secondGlyph),
+                              &kerning)) {
+        return 0;
+    }
+    return skhb_position(kerning);
+}
