+void Run::commit() {
+    if (!InternalLineMetrics::useQtLikeIntegerMetrics() || this->isPlaceholder()) {
+        return;
+    }
+
+    const auto rawPositions = fPositions;
+
+    SkScalar x = fPositions.empty() ? 0.0f : fPositions[0].fX;
+    SkScalar width = 0.0f;
+    for (size_t i = 0; i < this->size(); ++i) {
+        SkScalar advance =
+                SkScalarRoundToInt(rawPositions[i + 1].fX - rawPositions[i].fX);
+        fPositions[i].fX = x;
+        x += advance;
+        width += advance;
+    }
+    if (!fPositions.empty()) {
+        fPositions[this->size()].fX = x;
+    }
+    fAdvance.fX = width;
+}
