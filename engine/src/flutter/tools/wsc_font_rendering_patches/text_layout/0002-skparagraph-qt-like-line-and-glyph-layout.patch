+bool SkTypeface_FreeType::onGetQtLikeGlyphAdvance(SkGlyphID glyph,
+                                                  SkScalar textSize,
+                                                  SkScalar* advance) const {
+    if (!advance) {
+        return false;
+    }
+    *advance = 0;
+
+    AutoFTAccess fta(this);
+    FT_Face face = fta.face();
+    if (!face || !FT_IS_SCALABLE(face)) {
+        return false;
+    }
+
+    SkUniqueFTSize diagnosticSize([face]() -> FT_Size {
+        FT_Size size;
+        FT_Error err = FT_New_Size(face, &size);
+        if (err != 0) {
+            SK_TRACEFTR(err, "FT_New_Size(%s) failed in onGetQtLikeGlyphAdvance.",
+                        face->family_name);
+            return nullptr;
+        }
+        return size;
+    }());
+    if (!diagnosticSize) {
+        return false;
+    }
+
+    FT_Size oldSize = face->size;
+    FT_Matrix oldTransform;
+    FT_Vector oldDelta;
+    FT_Get_Transform(face, &oldTransform, &oldDelta);
+
+    FT_Error err = FT_Activate_Size(diagnosticSize.get());
+    if (err) {
+        return false;
+    }
+
+    FT_F26Dot6 scale = SkScalarToFDot6(textSize);
+    err = FT_Set_Char_Size(face, scale, scale, 72, 72);
+    if (err) {
+        FT_Activate_Size(oldSize);
+        FT_Set_Transform(face, &oldTransform, &oldDelta);
+        return false;
+    }
+
+    FT_Matrix matrix;
+    matrix.xx = 0x10000;
+    matrix.xy = 0;
+    matrix.yx = 0;
+    matrix.yy = 0x10000;
+    FT_Set_Transform(face, &matrix, nullptr);
+
+    FT_Int32 loadFlags = FT_LOAD_DEFAULT |
+                         FT_LOAD_IGNORE_GLOBAL_ADVANCE_WIDTH |
+                         FT_LOAD_TARGET_NORMAL |
+                         FT_LOAD_NO_BITMAP;
+    err = FT_Load_Glyph(face, glyph, loadFlags);
+    if (err) {
+        FT_Activate_Size(oldSize);
+        FT_Set_Transform(face, &oldTransform, &oldDelta);
+        return false;
+    }
+
+    *advance = SkIntToScalar(static_cast<int>((face->glyph->advance.x + 32) >> 6));
+    FT_Activate_Size(oldSize);
+    FT_Set_Transform(face, &oldTransform, &oldDelta);
+    return true;
+}
