+bool skhb_environment_variable_enabled(const char* value) {
+    return value != nullptr &&
+           (std::strcmp(value, "1") == 0 ||
+            std::strcmp(value, "true") == 0 ||
+            std::strcmp(value, "TRUE") == 0 ||
+            std::strcmp(value, "yes") == 0 ||
+            std::strcmp(value, "on") == 0);
+}
+
+bool skhb_environment_variable_disabled(const char* value) {
+    return value != nullptr &&
+           (std::strcmp(value, "0") == 0 ||
+            std::strcmp(value, "false") == 0 ||
+            std::strcmp(value, "FALSE") == 0 ||
+            std::strcmp(value, "no") == 0 ||
+            std::strcmp(value, "off") == 0);
+}
+
+bool skhb_use_qt_like_integer_metrics() {
+    const char* value = std::getenv("FLUTTER_QT_LINE_METRICS");
+    if (value == nullptr || *value == '\0') {
+        value = std::getenv("FLUTTER_INTEGER_TEXT_METRICS");
+    }
+    if (value == nullptr || *value == '\0') {
+        return true;
+    }
+    if (skhb_environment_variable_disabled(value)) {
+        return false;
+    }
+    return skhb_environment_variable_enabled(value);
+}
+
+bool skhb_qt_like_glyph_h_advance(const SkFont& font, SkGlyphID glyph, SkScalar* advance) {
+    SkTypeface* typeface = font.getTypeface();
+    return typeface != nullptr &&
+           typeface->getQtLikeGlyphAdvance(glyph, font.getSize(), advance);
+}
