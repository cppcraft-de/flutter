+static bool environment_variable_enabled(const char* value) {
+    return value != nullptr &&
+           (std::strcmp(value, "1") == 0 ||
+            std::strcmp(value, "true") == 0 ||
+            std::strcmp(value, "TRUE") == 0 ||
+            std::strcmp(value, "yes") == 0 ||
+            std::strcmp(value, "on") == 0);
+}
+
+static bool use_qt_like_integer_metrics() {
+    constexpr bool kUseQtLikeIntegerMetricsByDefault = true;
+    if (kUseQtLikeIntegerMetricsByDefault) {
+        return true;
+    }
+    const char* value = std::getenv("FLUTTER_QT_LINE_METRICS");
+    if (value == nullptr || *value == '\0') {
+        value = std::getenv("FLUTTER_INTEGER_TEXT_METRICS");
+    }
+    return environment_variable_enabled(value);
+}
