+Uint8Array MakePdf(JSArray pictures, Float32Array sourceSizes, double pageWidth,
+                   double pageHeight) {
+#ifndef SK_SUPPORT_PDF
+    SkDebugf("CanvasKit was built without PDF support.\n");
+    return emscripten::val::null();
+#else
+    const size_t pageCount = pictures["length"].as<size_t>();
+    if (pageCount == 0 || pageWidth <= 0 || pageHeight <= 0) {
+        return emscripten::val::null();
+    }
+
+    JSSpan<float> sizes(sourceSizes);
+    if (sizes.size() != pageCount * 2) {
+        return emscripten::val::null();
+    }
+
+    SkDynamicMemoryWStream stream;
+    sk_sp<SkDocument> document = SkPDF::MakeDocument(&stream);
+    if (!document) {
+        return emscripten::val::null();
+    }
+
+    for (size_t i = 0; i < pageCount; ++i) {
+        sk_sp<SkPicture> picture = pictures[i].as<sk_sp<SkPicture>>();
+        const float sourceWidth = sizes.data()[i * 2];
+        const float sourceHeight = sizes.data()[i * 2 + 1];
+        if (!picture || sourceWidth <= 0 || sourceHeight <= 0) {
+            return emscripten::val::null();
+        }
+
+        SkCanvas* canvas = document->beginPage(pageWidth, pageHeight);
+        if (!canvas) {
+            return emscripten::val::null();
+        }
+        canvas->save();
+        canvas->scale(pageWidth / sourceWidth, pageHeight / sourceHeight);
+        canvas->drawPicture(picture);
+        canvas->restore();
+        document->endPage();
+    }
+
+    document->close();
+    return toBytes(stream.detachAsData());
+#endif
+}
