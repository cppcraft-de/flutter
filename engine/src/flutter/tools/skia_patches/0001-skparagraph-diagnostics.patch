+std::vector<Paragraph::GlyphDiagnostic> ParagraphImpl::getGlyphDiagnostics() {
+    std::vector<Paragraph::GlyphDiagnostic> result;
+    int lineNumber = 0;
+    for (auto& line : fLines) {
+        line.ensureTextBlobCachePopulated();
+        for (auto& rec : line.fTextBlobCache) {
+            if (rec.fBlob == nullptr || rec.fVisitor_Run == nullptr) {
+                continue;
+            }
+            const Run* sourceRun = rec.fVisitor_Run;
+            size_t sourceIndex = rec.fVisitor_Pos;
+            SkTextBlob::Iter iter(*rec.fBlob);
+            SkTextBlob::Iter::ExperimentalRun blobRun;
+            while (iter.experimentalNext(&blobRun)) {
+                for (int i = 0; i < blobRun.count; ++i, ++sourceIndex) {
+                    const SkPoint shapePosition = sourceRun->fPositions[sourceIndex];
+                    const SkPoint offset = sourceRun->fOffsets[sourceIndex];
+                    const SkVector advance =
+                            sourceRun->fPositions[sourceIndex + 1] - shapePosition;
+                    const SkPoint finalOrigin = blobRun.positions[i] + rec.fOffset;
+                    const SkRect bounds = blobRun.font.getBounds(blobRun.glyphs[i], nullptr);
+                    result.push_back({
+                            lineNumber,
+                            sourceRun->fIndex,
+                            blobRun.font,
+                            blobRun.glyphs[i],
+                            SkToU32(sourceRun->globalClusterIndex(sourceIndex)),
+                            shapePosition,
+                            offset,
+                            advance,
+                            finalOrigin,
+                            bounds,
+                            bounds.makeOffset(finalOrigin),
+                    });
+                }
+            }
+        }
+        lineNumber += 1;
+    }
+    return result;
+}
